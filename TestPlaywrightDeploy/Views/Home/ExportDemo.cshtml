@{
    ViewData["Title"] = "导出演示";
}

<div class="container py-4">
    <div class="row mb-4">
        <div class="col-12">
            <div class="d-flex justify-content-between align-items-center">
                <h1 class="display-5">📄 导出演示页面</h1>
                <button id="exportPdfBtn" class="btn btn-primary btn-lg">
                    <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="currentColor" class="bi bi-file-earmark-pdf me-2" viewBox="0 0 16 16">
                        <path d="M14 4.5V14a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V2a2 2 0 0 1 2-2h5.5L14 4.5zm-3 0A1.5 1.5 0 0 1 9.5 3V1H4a1 1 0 0 0-1 1v12a1 1 0 0 0 1 1h8a1 1 0 0 0 1-1V4.5h-2z"/>
                        <path d="M4.5 6a.5.5 0 0 0-.5.5v3a.5.5 0 0 0 .5.5h1.5a1.5 1.5 0 0 0 0-3H4.5zm1.5 2a.5.5 0 0 1-.5.5H5V7h.5a.5.5 0 0 1 .5.5v.5zM8.5 6a.5.5 0 0 0-.5.5v3a.5.5 0 0 0 .5.5H10a1 1 0 0 0 1-1V7a1 1 0 0 0-1-1H8.5zm.5 3V7H10v2H9z"/>
                        <path d="M11.5 9.5A.5.5 0 0 1 12 9h1.5a.5.5 0 0 1 0 1H12v1.5a.5.5 0 0 1-1 0v-2z"/>
                    </svg>
                    导出 PDF
                </button>
            </div>
            <hr/>
        </div>
    </div>

    <!-- 卡片区域: 统计数据 -->
    <div class="row mb-4">
        <div class="col-md-4">
            <div class="card text-white bg-primary mb-3">
                <div class="card-header">用户数</div>
                <div class="card-body">
                    <h3 class="card-title">12,847</h3>
                    <p class="card-text">较上月增长 +12.5%</p>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card text-white bg-success mb-3">
                <div class="card-header">订单数</div>
                <div class="card-body">
                    <h3 class="card-title">3,562</h3>
                    <p class="card-text">较上月增长 +8.3%</p>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card text-white bg-warning mb-3">
                <div class="card-header">收入</div>
                <div class="card-body">
                    <h3 class="card-title">¥ 289,450</h3>
                    <p class="card-text">较上月增长 +15.7%</p>
                </div>
            </div>
        </div>
    </div>

    <!-- 表格数据 -->
    <div class="row mb-4">
        <div class="col-12">
            <div class="card">
                <div class="card-header">
                    <h5 class="mb-0">📊 近期销售数据</h5>
                </div>
                <div class="card-body">
                    <table class="table table-striped table-hover">
                        <thead class="table-dark">
                        <tr>
                            <th>#</th>
                            <th>产品名称</th>
                            <th>类别</th>
                            <th>销量</th>
                            <th>金额</th>
                        </tr>
                        </thead>
                        <tbody>
                        <tr>
                            <td>1</td>
                            <td>智能手表 Pro</td>
                            <td>电子产品</td>
                            <td>1,280</td>
                            <td>¥ 384,000</td>
                        </tr>
                        <tr>
                            <td>2</td>
                            <td>无线降噪耳机</td>
                            <td>音频设备</td>
                            <td>2,450</td>
                            <td>¥ 367,500</td>
                        </tr>
                        <tr>
                            <td>3</td>
                            <td>机械键盘 K8</td>
                            <td>电脑外设</td>
                            <td>980</td>
                            <td>¥ 156,800</td>
                        </tr>
                        <tr>
                            <td>4</td>
                            <td>4K 便携显示器</td>
                            <td>显示设备</td>
                            <td>560</td>
                            <td>¥ 280,000</td>
                        </tr>
                        <tr>
                            <td>5</td>
                            <td>人体工学椅</td>
                            <td>办公家具</td>
                            <td>320</td>
                            <td>¥ 192,000</td>
                        </tr>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>

    <!-- 文本内容区域 -->
    <div class="row mb-4">
        <div class="col-12">
            <div class="card">
                <div class="card-header">
                    <h5 class="mb-0">📝 项目说明</h5>
                </div>
                <div class="card-body">
                    <p>本项目用于测试在 ASP.NET Core MVC 项目中集成 Playwright 进行 PDF 导出，并通过 Docker 部署到 Linux 环境。</p>
                    <ul>
                        <li><strong>框架</strong>：ASP.NET Core MVC (.NET 10)</li>
                        <li><strong>导出引擎</strong>：Microsoft.Playwright v1.56.0</li>
                        <li><strong>部署方式</strong>：Docker (Linux 容器)</li>
                        <li><strong>浏览器</strong>：Chromium (无头模式)</li>
                    </ul>
                    <div class="alert alert-info">
                        <strong>💡 提示：</strong>点击右上角的 "导出 PDF" 按钮，服务端将使用 Playwright 渲染当前页面并生成 PDF 文件下载。
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        document.getElementById('exportPdfBtn').addEventListener('click', async function() {
            const btn = this;
            const originalText = btn.innerHTML;
            btn.disabled = true;
            btn.innerHTML = '<span class="spinner-border spinner-border-sm me-2" role="status"></span> 导出中...';

            try {
                const response = await fetch('/Home/ExportPdf', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ url: window.location.href })
                });

                if (!response.ok) {
                    throw new Error('导出失败: ' + response.statusText);
                }

                // 将返回的二进制数据转为 Blob 并下载
                const blob = await response.blob();
                const link = document.createElement('a');
                link.href = URL.createObjectURL(blob);
                link.download = 'export-demo.pdf';
                document.body.appendChild(link);
                link.click();
                document.body.removeChild(link);
                URL.revokeObjectURL(link.href);
            } catch (err) {
                alert('导出出错: ' + err.message);
            } finally {
                btn.disabled = false;
                btn.innerHTML = originalText;
            }
        });
    </script>
}
